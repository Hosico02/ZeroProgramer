#!/usr/bin/env bash
# tm-issue-finalize <issue-number>
#
# Called by tm-done as a task's signal_cmd. Run from inside the per-issue
# worktree. On success: pushes the auto-fix branch, opens a PR (idempotent)
# with a structured "整体方案" body (commit msg, files, diff stat), posts a
# short pointer comment on the issue, exits 0. PR is the artifact the owner
# reviews against the issue — bot never auto-merges. On any safety/validation
# failure: exits non-zero with a reason on stderr.
#
# Required env:
#   TM_BOT_ROOT             absolute path to gh-issue-bot/
#   TM_GH_REPO              owner/repo (target of the PR)
#   TM_ISSUE_BRANCH_PREFIX  e.g. "auto-fix/issue-"
# Optional:
#   TM_ISSUE_MAX_DIFF_LINES default 2000; 0 disables
set -euo pipefail

if [ $# -lt 1 ]; then echo "usage: tm-issue-finalize <issue#>" >&2; exit 64; fi
ISSUE="$1"
[ -n "${TM_BOT_ROOT:-}" ]              || { echo "TM_BOT_ROOT unset" >&2; exit 2; }
MAX_DIFF="${TM_ISSUE_MAX_DIFF_LINES:-2000}"

# 1. cwd lock — must resolve inside TM_BOT_ROOT/worktrees/issue-<N>
# This runs before all other env checks so cwd errors surface first.
CWD_REAL="$(cd "$PWD" && pwd -P)"
BOT_ROOT_REAL="$(cd "$TM_BOT_ROOT" 2>/dev/null && pwd -P)" \
  || { echo "finalize refused: TM_BOT_ROOT '$TM_BOT_ROOT' does not exist; cwd not in expected worktree" >&2; exit 10; }
WT_REQUIRED="${BOT_ROOT_REAL}/worktrees/issue-${ISSUE}"
if [ "$CWD_REAL" != "$WT_REQUIRED" ]; then
  echo "finalize refused: cwd '$CWD_REAL' is not the expected worktree '$WT_REQUIRED'" >&2
  exit 10
fi

# 2. Branch prefix env check + branch lock (before TM_GH_REPO so branch errors surface early)
[ -n "${TM_ISSUE_BRANCH_PREFIX:-}" ]   || { echo "TM_ISSUE_BRANCH_PREFIX unset" >&2; exit 2; }
HEAD_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
case "$HEAD_BRANCH" in
  "$TM_ISSUE_BRANCH_PREFIX"*) ;;
  *) echo "finalize refused: HEAD branch '$HEAD_BRANCH' lacks prefix '$TM_ISSUE_BRANCH_PREFIX'" >&2; exit 11 ;;
esac

# 3. Remaining env validation (after structural checks)
[ -n "${TM_GH_REPO:-}" ]               || { echo "TM_GH_REPO unset" >&2; exit 2; }

# 3. diff existence check
if git diff --quiet main -- 2>/dev/null && git diff --cached --quiet main -- 2>/dev/null; then
  # Nothing changed at all relative to main.
  echo "finalize refused: empty diff against main (session produced no changes)" >&2
  exit 12
fi

# 4. diff size guard
if [ "$MAX_DIFF" != "0" ]; then
  changed=$(git diff main -- 2>/dev/null | grep -E '^[+-]' | grep -Ev '^(\+\+\+|---)' | wc -l | tr -d ' ')
  if [ "$changed" -gt "$MAX_DIFF" ]; then
    echo "finalize refused: diff size $changed lines exceeds TM_ISSUE_MAX_DIFF_LINES=$MAX_DIFF" >&2
    exit 13
  fi
fi

# 5. Push (idempotent). Use plain push if no upstream is set yet, otherwise
# --force-with-lease to refuse to overwrite remote changes we haven't seen.
if git rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1; then
  git push --force-with-lease origin "HEAD:$HEAD_BRANCH" >/dev/null
else
  git push -u origin "HEAD:$HEAD_BRANCH" >/dev/null
fi

# 6. Compose the "整体方案" — goes into the PR body so it shows up in the
# review UI alongside the diff. Issue comment gets a short pointer.
COMMIT_SHA="$(git log -1 --format=%H)"
COMMIT_SHORT="${COMMIT_SHA:0:8}"
COMMIT_SUBJECT="$(git log -1 --format=%s)"
COMMIT_BODY="$(git log -1 --format=%b)"
DIFF_STAT="$(git diff main --stat)"

# Optional cost report (set by tm-issue-bot-resolve when calling us).
COST_FOOTER=""
COMMENT_COST_TAIL=""
if [ -n "${TM_FIXER_COST_USD:-}" ]; then
  COST_FOOTER="

### 成本

\`\$${TM_FIXER_COST_USD}\` · ${TM_FIXER_TOKENS_IN:-?}↑ + ${TM_FIXER_TOKENS_OUT:-?}↓ tokens (cache c/r: ${TM_FIXER_CACHE_C:-?}/${TM_FIXER_CACHE_R:-?}) · ${TM_FIXER_DURATION:-?}s · ${TM_FIXER_TURNS:-?} turns · model \`${TM_FIXER_MODEL:-?}\`"
  COMMENT_COST_TAIL=" · 成本 \$${TM_FIXER_COST_USD} (${TM_FIXER_TOKENS_IN:-?}↑+${TM_FIXER_TOKENS_OUT:-?}↓ tokens, ${TM_FIXER_DURATION:-?}s)"
fi

PR_BODY="$(cat <<EOF
Closes #${ISSUE}

**🤖 gh-issue-bot 自动修复 — 请 review 后 merge。**

### 修复说明

**${COMMIT_SUBJECT}**

${COMMIT_BODY:-_(commit 没写正文，仅有 subject)_}

### 改动文件

\`\`\`
${DIFF_STAT}
\`\`\`

### Commit

\`${COMMIT_SHORT}\`${COST_FOOTER}

---
_由 gh-issue-bot 在 worktree \`worktrees/issue-${ISSUE}/\` 内自动产出。bot 永不 auto-merge —— 由 owner 根据 issue 自行确认。_
EOF
)"

# 7. PR — open if missing, else reuse number (idempotent).
PR_NUM=$(gh pr list --repo "$TM_GH_REPO" --head "$HEAD_BRANCH" --state open --json number 2>/dev/null \
         | jq -r '.[0].number // empty' 2>/dev/null || true)
if [ -z "$PR_NUM" ] || [ "$PR_NUM" = "null" ]; then
  PR_TITLE="Auto-fix #${ISSUE}: ${COMMIT_SUBJECT}"
  PR_URL=$(gh pr create --repo "$TM_GH_REPO" --head "$HEAD_BRANCH" --base main \
           --title "$PR_TITLE" --body "$PR_BODY")
  PR_NUM=$(printf '%s' "$PR_URL" | grep -oE '/pull/[0-9]+' | grep -oE '[0-9]+' | tail -1)
fi

# 8. Issue gets a short pointer; full solution lives in the PR body.
gh issue comment "$ISSUE" --repo "$TM_GH_REPO" \
  --body "🤖 已开 PR #${PR_NUM}（branch \`${HEAD_BRANCH}\`，commit \`${COMMIT_SHORT}\`），请 review 后决定是否 merge。完整修复说明见 PR 正文。${COMMENT_COST_TAIL}" >/dev/null

echo "ok pr=$PR_NUM branch=$HEAD_BRANCH commit=$COMMIT_SHORT cost=${TM_FIXER_COST_USD:-n/a} dur=${TM_FIXER_DURATION:-n/a}s"
