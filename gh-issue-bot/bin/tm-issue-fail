#!/usr/bin/env bash
# tm-issue-fail <issue#> "<reason>"
#
# Posts a "auto-fix-failed: <reason>" comment on the issue and adds the
# fail label. Used by tm-issue-watcher when an attempt is permanently lost.
set -euo pipefail

if [ $# -lt 2 ]; then
  echo "usage: tm-issue-fail <issue#> <reason>" >&2
  exit 64
fi
ISSUE="$1"; shift
REASON="$*"

[ -n "${TM_GH_REPO:-}" ]         || { echo "TM_GH_REPO unset" >&2; exit 2; }
LABEL="${TM_ISSUE_FAIL_LABEL:-auto-fix-failed}"

# Optional cost report from the resolver
COST_LINE=""
if [ -n "${TM_FIXER_COST_USD:-}" ]; then
  COST_LINE="

### 本次尝试成本

\`\$${TM_FIXER_COST_USD}\` · ${TM_FIXER_TOKENS_IN:-?}↑ + ${TM_FIXER_TOKENS_OUT:-?}↓ tokens · ${TM_FIXER_DURATION:-?}s · model \`${TM_FIXER_MODEL:-?}\`"
fi

BODY="$(cat <<EOF
**🤖 gh-issue-bot 尝试自动解决此 issue 失败。**

### 失败原因

${REASON}

### bot 都做了什么

- 在 worktree \`worktrees/issue-${ISSUE}/\` 内启动了一个隔离的 Claude session
- 让它读 issue 的 title + body 后在 worktree 里编辑代码
- 该 session 未能产出可推送的修复（详见上面的失败原因）

### 接下来你可以

1. **改进 issue body** 让 bot 下次能理解：明确指出文件路径、需要的修改、验收方式
2. **手动撤掉 \`${LABEL}\` 标签** —— 撤掉后 bot 下次 tick 会重试
3. **手动关掉这个 issue** —— 如果你认为不该自动修

> bot 不会自动重试带 \`${LABEL}\` 标签的 issue，避免反复烧 token。${COST_LINE}
EOF
)"

gh issue comment "$ISSUE" --repo "$TM_GH_REPO" --body "$BODY" >/dev/null
gh issue edit    "$ISSUE" --repo "$TM_GH_REPO" --add-label "$LABEL" >/dev/null
echo "ok labelled=$LABEL"
