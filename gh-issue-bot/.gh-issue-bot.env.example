# Copy to .gh-issue-bot.env and edit. Values shown are defaults.

# Target repo (owner/name). If unset, derived from `git remote get-url origin`.
# TM_GH_REPO=owner/repo

# Required label. Issues missing this label are ignored.
TM_ISSUE_LABEL=auto-fix

# Applied when an attempt fails terminally. Issues with this label are skipped.
TM_ISSUE_FAIL_LABEL=auto-fix-failed

# Concurrency cap on in-flight fixer sessions. With unified-branch mode
# (default), this is forced to 1 internally — multiple issues share one
# branch and must commit sequentially.
TM_ISSUE_MAX_PARALLEL=1

# Polling cadence (seconds). Match this to the scheduler interval.
TM_ISSUE_POLL_INTERVAL=600

# Hard stop on the number of fixer spawns per UTC day.
TM_ISSUE_DAILY_CAP=10

# Refuse to push diffs larger than this (lines). Use 0 to disable the cap.
TM_ISSUE_MAX_DIFF_LINES=2000

# Single shared branch where all auto-fix commits accumulate. One PR
# (TM_ISSUE_BRANCH_PREFIX → main) is reused across issues; each commit
# Closes the corresponding issue. Despite the legacy name, this is now
# the literal branch name (not a prefix).
TM_ISSUE_BRANCH_PREFIX=auto-fix

# Model used by the headless `claude -p` fixer. Cheaper = faster but lower accuracy.
TM_FIXER_MODEL=claude-haiku-4-5

# Per-issue spend cap (USD). Resolver fails the issue if claude exceeds this budget.
TM_FIXER_MAX_USD=0.10
