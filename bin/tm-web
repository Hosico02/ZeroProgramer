        <button id="btn-sync-now" class="btn">立即同步</button>
      </div>
      <div id="loop-countdown" class="small">—</div>
    </div>

    <div class="grid">
      <div class="card">
        <h2>Escalation → Issue mapping</h2>
        <table id="issue-map">
          <thead><tr><th>file</th><th>issue</th><th>title</th></tr></thead>
          <tbody></tbody>
        </table>
        <div id="issue-summary" class="small" style="margin-top:.5rem;color:var(--muted);">—</div>
      </div>

      <div class="card">
        <h2>Open escalations <span class="small">on disk</span></h2>
        <ul id="escalations" class="clean"></ul>
      </div>
    </div>

    <div class="grid" style="margin-top:1rem;">
      <div class="card full">
        <h2>gh-sync.log <span class="small">last 25 entries</span></h2>
        <pre id="sync-log">—</pre>
      </div>
    </div>
  </div>

  <!-- modal -->
  <div id="modal-bg" class="modal-bg">
    <div class="modal">
      <header>
        <div class="title" id="modal-title">—</div>
        <div class="name mono" id="modal-name">—</div>
        <div class="close" id="modal-close">✕</div>
      </header>
      <div class="body" id="modal-body">loading…</div>
    </div>
  </div>

  <!-- toast -->
  <div id="toast" class="toast">—</div>

<script>
const $ = id => document.getElementById(id);

let LATEST_STATE = null;

// ─── tab switching ───
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    const tab = t.dataset.tab;
    document.querySelectorAll('.tab').forEach(x => x.classList.toggle('active', x === t));
    document.querySelectorAll('.tab-content').forEach(x => x.classList.toggle('active', x.dataset.tab === tab));
  });
});

// ─── helpers ───
function escape_html(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}
function pct_class(p) { return p >= 0.85 ? "red" : (p >= 0.6 ? "yellow" : "green"); }
function fmt_until(epoch) {
  if (!epoch) return "—";
  const secs = epoch - Math.floor(Date.now() / 1000);
  if (secs <= 0) return "now";
  const h = Math.floor(secs / 3600), m = Math.floor((secs % 3600) / 60), s = secs % 60;
  if (h >= 24) return `${Math.floor(h/24)}d${h%24}h`;
  if (h)      return `${h}h${String(m).padStart(2,"0")}m`;
  if (m)      return `${m}m${String(s).padStart(2,"0")}s`;
  return `${s}s`;
}
function fmt_ago(epoch) {
  if (!epoch) return "—";
  const secs = Math.floor(Date.now() / 1000) - epoch;
  if (secs < 60) return secs + "s ago";
  if (secs < 3600) return Math.floor(secs/60) + "m ago";
  return Math.floor(secs/3600) + "h ago";
}

// ─── toast ───
let toastTimer = null;
function toast(msg, kind="ok") {
  const t = $("toast");
  t.textContent = msg;
  t.className = "toast show " + kind;
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.className = "toast " + kind, 2400);
}

// ─── modal ───
$("modal-close").addEventListener("click", () => $("modal-bg").classList.remove("show"));
$("modal-bg").addEventListener("click", e => {
  if (e.target === $("modal-bg")) $("modal-bg").classList.remove("show");
});
async function open_file(rel_path, title) {
  $("modal-title").textContent = title;
  $("modal-name").textContent = rel_path;
  $("modal-body").innerHTML = "<pre>loading…</pre>";
  $("modal-bg").classList.add("show");
  try {
    const r = await fetch("/api/file?path=" + encodeURIComponent(rel_path));
    if (!r.ok) {
      const txt = await r.text();
      $("modal-body").innerHTML = "<pre>error: " + escape_html(txt) + "</pre>";
      return;
    }
    const txt = await r.text();
    $("modal-body").innerHTML = "<pre>" + escape_html(txt) + "</pre>";
  } catch (e) {
    $("modal-body").innerHTML = "<pre>fetch failed: " + escape_html(String(e)) + "</pre>";
  }
}

// ─── team control ───
async function team_action(path, body) {
  try {
    const r = await fetch("/api/team/" + path, {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: body ? JSON.stringify(body) : "{}",
    });
    const d = await r.json();
    if (d.ok) {
      toast(d.message || "ok", "ok");
    } else {
      toast(d.error || "failed", "err");
    }
    refresh();
  } catch (e) {
    toast("network: " + e, "err");
  }
}
$("btn-start").addEventListener("click", () => {
  const n = parseInt($("n-executors").value, 10) || 1;
  team_action("start", {executors: n});
});
$("btn-add").addEventListener("click", () => team_action("add-executor"));
$("btn-stop").addEventListener("click", () => {
  if (confirm("停止全部 agents？")) team_action("stop");
});
$("btn-sync-now").addEventListener("click", async () => {
  toast("running tm-github-sync …", "ok");
  try {
    const r = await fetch("/api/sync-now", {method: "POST"});
    const d = await r.json();
    toast(d.ok ? "synced" : (d.error || "failed"), d.ok ? "ok" : "err");
    refresh();
  } catch (e) {
    toast("network: " + e, "err");
  }
});

// ─── refresh ───
async function refresh() {
  try {
    const r = await fetch("/api/state");
    if (!r.ok) throw new Error("HTTP " + r.status);
    const s = await r.json();
    LATEST_STATE = s;
    render(s);
  } catch (e) {
    $("proj").textContent = "(server unreachable)";
  }
}

function render(s) {
  // ── topbar ──
  const dot = s.daemon_running ? '<span class="dot green">●</span>' : '<span class="dot muted">○</span>';
  $("proj").innerHTML = `${dot} ${escape_html(s.project)}`;
  $("ts").textContent = new Date().toLocaleTimeString();
  $("pm-status").innerHTML = s.daemon_running
    ? '<span class="pill green">PM running</span>'
    : '<span class="pill muted">PM stopped</span>';

  // ── budget pill ──
  const b = s.cc_budget || {};
  if (b.available && b.h5_pct != null) {
    const cls5 = pct_class(b.h5_pct);
    const cls7 = pct_class(b.d7_pct || 0);
    $("budget-row").innerHTML =
      `<span class="pill ${cls5}">5h ${(b.h5_pct*100).toFixed(0)}%</span>` +
      `<span class="pill ${cls7}">7d ${(b.d7_pct ? b.d7_pct*100 : 0).toFixed(0)}%</span>` +
      (b.stale ? '<span class="pill yellow">stale</span>' : '');
  } else {
    $("budget-row").innerHTML = '<span class="small" style="color:var(--muted);">budget cache n/a</span>';
  }

  // ── team summary + buttons ──
  const agents = s.agents || [];
  const sup = agents.find(a => a.role === "supervisor");
  const execs = agents.filter(a => a.role === "executor");
  $("team-summary").textContent = sup
    ? `· 1 supervisor + ${execs.length} executor(s) running`
    : "· no agents running";
  $("btn-start").disabled = !!sup;
  $("btn-add").disabled = !sup;
  $("btn-stop").disabled = agents.length === 0;

  // ── progress ──
  const ts = s.tasks || [];
  const done = ts.filter(t => t.status === "done").length;
  const inpg = ts.filter(t => t.status === "in-progress").length;
  const fail = ts.filter(t => t.status === "failed").length;
  const todo = ts.length - done - inpg - fail;
  const pct = ts.length ? Math.round(100 * done / ts.length) : 0;
  $("progress").innerHTML =
    `<div style="font-size:1.55rem; margin-bottom:.4rem;">
       ${done}<span class="small" style="color:var(--muted);">/${ts.length}</span>
       <span class="pill ${done === ts.length && ts.length ? 'green' : 'blue'}" style="margin-left:.5rem;">${pct}%</span>
     </div>
     <div class="pbar big"><div class="fill ${pct >= 100 ? 'green' : 'yellow'}" style="width:${pct}%"></div></div>
     <div>
       <span class="pill green">${done} done</span>
       <span class="pill yellow">${inpg} in-progress</span>
       <span class="pill muted">${todo} todo</span>
       ${fail ? `<span class="pill red">${fail} failed</span>` : ""}
     </div>`;

  // ── workers (combine pm-state.workers + scanned agents) ──
  const wTbody = $("workers-table").querySelector("tbody");
  const stateWorkers = Object.entries(s.workers || {});
  if (!stateWorkers.length && !agents.length) {
    wTbody.innerHTML = '<tr><td colspan="4" class="small" style="color:var(--muted);">(no workers — click ▶ 启动 above)</td></tr>';
  } else {
    // Prefer pm-state info; supplement with agents that haven't joined PM yet.
    const seenSids = new Set(stateWorkers.map(([sid]) => sid));
    const rows = stateWorkers.map(([sid, w]) => {
      const role = w.role || "executor";
      const cur = w.current_task_id != null ? `task #${w.current_task_id}` : "—";
      return `<tr>
        <td class="mono">${sid.slice(0,12)}</td>
        <td class="role-${role}">${role}</td>
        <td>${escape_html(w.status || "?")}</td>
        <td>${cur}</td>
      </tr>`;
    });
    // Add agents pre-PM-join (rare but happens on first start)
    agents.forEach(a => {
      if (!stateWorkers.some(([_, w]) => (w.label || "") === a.label)) {
        // not in state — show as starting
        rows.push(`<tr>
          <td class="mono">pid ${a.pid}</td>
          <td class="role-${a.role}">${a.role}</td>
          <td><span class="small">starting…</span></td>
          <td>—</td>
        </tr>`);
      }
    });
    wTbody.innerHTML = rows.join("") || '<tr><td colspan="4" class="small">—</td></tr>';
  }

  // ── tasks ──
  const tTbody = $("tasks-table").querySelector("tbody");
  if (!ts.length) {
    tTbody.innerHTML = '<tr><td colspan="3" class="small" style="color:var(--muted);">(no tasks yet — supervisor will plan once agents start)</td></tr>';
  } else {
    const mark = { done:"✓", "in-progress":"▶", failed:"✗", todo:"·" };
    tTbody.innerHTML = ts.slice(-15).map(t => {
      const cls = t.status === "done" ? "green"
                : t.status === "in-progress" ? "yellow"
                : t.status === "failed" ? "red" : "muted";
      return `<tr>
        <td>#${t.id}</td>
        <td><span class="pill ${cls}">${mark[t.status] || "?"} ${t.status}</span></td>
        <td class="truncate" title="${escape_html(t.title || "")}">${escape_html(t.title || "")}</td>
      </tr>`;
    }).join("");
  }

  $("recent-events").textContent = (s.recent_events || []).join("\n") || "(no events)";
  $("supervisor-log").textContent = (s.supervisor_recent || []).join("\n") || "(no supervisor decisions yet)";

  // ── click-to-view file lists ──
  fill_file_list("status-reports", s.status_reports || [], "Status report");
  fill_file_list("decisions", s.decisions || [], "Decision");
  fill_file_list("proposals", s.proposals || [], "Proposal");

  // escalations: just show name (we render mapping in Issue tab)
  const escUl = $("escalations");
  const escs = s.escalations || [];
  if (!escs.length) {
    escUl.innerHTML = '<li class="small" style="color:var(--muted);">(none) ✓</li>';
  } else {
    escUl.innerHTML = escs.map(e =>
      `<li onclick='open_file(${JSON.stringify(e.rel_path)}, ${JSON.stringify("Escalation")})'>` +
      `<span class="name">${escape_html(e.name)}</span><span class="title">${escape_html(e.title)}</span></li>`
    ).join("");
  }

  // ── Issue 管理 tab ──
  $("repo-label").textContent = "· repo: " + (s.repo || "(no remote)");
  const gh = s.gh_sync || {};
  const dot2 = gh.loop_alive ? '<span class="dot green">●</span>' : '<span class="dot muted">○</span>';
  const stateStr = gh.loop_alive
    ? `loop alive · state: <span class="pill ${gh.last_result === 'failed' ? 'red' : (gh.state === 'running' ? 'yellow' : 'green')}">${gh.state} (${gh.last_result})</span>`
    : 'loop not running';
  $("loop-status").innerHTML = `${dot2} ${stateStr}`;

  const intervalMin = Math.round((gh.interval_sec || 1800) / 60);
  if (gh.loop_alive && gh.next_run_ts) {
    $("loop-countdown").innerHTML =
      `interval: every ${intervalMin} min · next sync in <strong>${fmt_until(gh.next_run_ts)}</strong> · last run ${fmt_ago(gh.last_run_ts)}`;
  } else {
    $("loop-countdown").innerHTML = `interval: ${intervalMin} min · loop stopped — start with <code>./bin/tm-gh-sync-loop --forever &amp;</code>`;
  }

  // mapping table
  const mapTbody = $("issue-map").querySelector("tbody");
  const mapping = gh.mapping || {};
  const entries = Object.entries(mapping);
  if (!entries.length) {
    mapTbody.innerHTML = '<tr><td colspan="3" class="small" style="color:var(--muted);">(no mapping yet — runs after first escalation)</td></tr>';
  } else {
    const repo_url = s.repo ? `https://github.com/${s.repo}/issues/` : null;
    mapTbody.innerHTML = entries.map(([fname, info]) => {
      let num, title = "", state = "";
      if (info && typeof info === "object") {
        num = info.number || info.issue || "—";
        title = info.title || "";
        state = info.state || "";
      } else { num = info; }
      const issueCell = repo_url
        ? `<a href="${repo_url}${num}" target="_blank">#${num}</a>` + (state ? ` <span class="pill muted">${escape_html(state)}</span>` : "")
        : `#${num}` + (state ? ` (${escape_html(state)})` : "");
      return `<tr>
        <td class="mono">${escape_html(fname)}</td>
        <td>${issueCell}</td>
        <td class="truncate" title="${escape_html(title)}">${escape_html(title)}</td>
      </tr>`;
    }).join("");
  }
  const onDisk = gh.escalations_on_disk || 0;
  const mappedCount = entries.length;
  const mapMtime = gh.map_mtime ? fmt_ago(gh.map_mtime) : "(never)";
  $("issue-summary").textContent = `escalations on disk: ${onDisk} · mapped: ${mappedCount} · last sync wrote map: ${mapMtime}`;

  $("sync-log").textContent = (gh.log_tail || []).join("\n") || "(no sync activity yet)";
}

function fill_file_list(id, items, kind) {
  const ul = $(id);
  if (!items.length) {
    ul.innerHTML = '<li class="small" style="color:var(--muted);">(none yet)</li>';
    return;
  }
  ul.innerHTML = items.map(it =>
    `<li onclick='open_file(${JSON.stringify(it.rel_path)}, ${JSON.stringify(kind + ": " + it.title)})'>` +
    `<span class="name">${escape_html(it.name)}</span>` +
    `<span class="title">${escape_html(it.title)}</span>` +
    `</li>`
  ).join("");
}

refresh();
setInterval(refresh, 1000);
</script>
</body>
</html>
"""


# ============================================================ HTTP impl ===
class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *a, **kw):
        pass  # silence default access logs

    # ---- routing ----
    def do_GET(self):
        u = urllib.parse.urlparse(self.path)
        path = u.path
        if path in ("/", "/index.html"):
            return self._send(200, "text/html; charset=utf-8", INDEX_HTML.encode())
        if path == "/api/state":
            return self._send_json(200, self._build_state())
        if path == "/api/file":
            return self._serve_file(u.query)
        return self._send(404, "text/plain", b"not found")

    def do_POST(self):
        u = urllib.parse.urlparse(self.path)
        path = u.path
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except Exception:
            length = 0
        body = self.rfile.read(length) if length > 0 else b""
        try:
            data = json.loads(body) if body else {}
        except Exception:
            data = {}

        if path == "/api/team/start":
            return self._send_json(200, self._team_start(data))
        if path == "/api/team/add-executor":
            return self._send_json(200, self._team_add_executor())
        if path == "/api/team/stop":
            return self._send_json(200, self._team_stop())
        if path == "/api/sync-now":
            return self._send_json(200, self._sync_now())
        return self._send(404, "text/plain", b"not found")

    # ---- impl ----
    def _send(self, code, ctype, body):
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_json(self, code, payload):
        return self._send(code, "application/json", json.dumps(payload).encode())

    def _build_state(self) -> dict:
        s = read_state()
        return {
            "project": ROOT.name,
            "repo": cached_repo(),
            "daemon_running": daemon_running(),
            "tasks": s.get("tasks", []),
            "workers": s.get("workers", {}),
            "agents": scan_agents(),
            "recent_events": tail_log(LOG_FILE, 20),
            "supervisor_recent": tail_log(SUPERVISOR_LOG, 12),
            "escalations": list_dir_md(ESC_DIR, 12),
            "status_reports": list_dir_md(STATUS_REPORTS_DIR, 10),
            "decisions": list_dir_md(DECISIONS_DIR, 10),
            "proposals": list_dir_md(PROPOSALS_DIR, 10),
            "cc_budget": read_cc_budget(),
            "gh_sync": read_gh_sync(),
            "ts": datetime.datetime.utcnow().isoformat() + "Z",
        }

    def _serve_file(self, query: str):
        params = urllib.parse.parse_qs(query)
        rel = (params.get("path") or [""])[0]
        if not rel:
            return self._send(400, "text/plain", b"missing ?path=")
        try:
            target = (ROOT / rel).resolve()
        except Exception:
            return self._send(400, "text/plain", b"bad path")
        # Sandbox: must be inside one of the allowed dirs.
        ok = False
        for d in FILE_VIEWER_DIRS:
            try:
                target.relative_to(d.resolve())
                ok = True
                break
            except (ValueError, FileNotFoundError):
                continue
        if not ok:
            return self._send(403, "text/plain", b"outside allowed dirs")
        if not target.is_file():
            return self._send(404, "text/plain", b"not found")
        try:
            data = target.read_bytes()
        except Exception as e:
            return self._send(500, "text/plain", f"read failed: {e}".encode())
        return self._send(200, "text/plain; charset=utf-8", data)

    # ---- team control ----
    def _team_start(self, data: dict) -> dict:
        if has_supervisor():
            return {"ok": False, "error": "supervisor already running"}
        try:
            n = int(data.get("executors", 1))
        except Exception:
            n = 1
        n = max(0, min(n, 8))
        results = []
        sup = spawn_agent("supervisor", WRAPPER_SUPERVISOR)
        results.append({"role": "supervisor", **sup})
        if not sup.get("ok"):
            return {"ok": False, "error": "supervisor: " + sup.get("error", "?"), "results": results}
        for i in range(1, n + 1):
            r = spawn_agent(f"executor-{i}", WRAPPER_EXECUTOR)
            results.append({"role": "executor", "n": i, **r})
        return {"ok": True, "message": f"started supervisor + {n} executor(s)", "results": results}

    def _team_add_executor(self) -> dict:
        if not has_supervisor():
            return {"ok": False, "error": "no supervisor running — click ▶ 启动 first"}
        n = next_executor_index()
        r = spawn_agent(f"executor-{n}", WRAPPER_EXECUTOR)
        if not r.get("ok"):
            return {"ok": False, "error": r.get("error", "?")}
        return {"ok": True, "message": f"added executor-{n} (pid {r.get('pid')})", "result": r}

    def _team_stop(self) -> dict:
        r = stop_all_agents()
        return {"ok": True, "message": f"stopped {len(r['stopped'])} agent(s)", **r}

    def _sync_now(self) -> dict:
        try:
            res = subprocess.run(
                [str(ROOT / "bin" / "tm-github-sync")],
                cwd=str(ROOT), capture_output=True, text=True, timeout=120,
            )
            if res.returncode != 0:
                return {"ok": False, "error": (res.stderr or res.stdout or "non-zero exit")[:300]}
            return {"ok": True, "message": (res.stdout or "synced").strip()[:300]}
        except Exception as e:
            return {"ok": False, "error": str(e)}


class ReusableServer(socketserver.ThreadingTCPServer):
    allow_reuse_address = True


def main() -> int:
    port = 7891
    open_browser = True
    strict_port = False
    for arg in sys.argv[1:]:
        if arg == "--no-open":
            open_browser = False
        elif arg == "--strict-port":
            strict_port = True
        elif arg.isdigit():
            port = int(arg)
        elif arg in ("-h", "--help"):
            print(__doc__)
            return 0
        else:
            print(f"tm-web: unknown arg {arg!r}", file=sys.stderr)
            return 1

    MAX_TRIES = 1 if strict_port else 10
    server = None
    last_err = None
    for attempt in range(MAX_TRIES):
        try_port = port + attempt
        try:
            server = ReusableServer(("127.0.0.1", try_port), Handler)
            port = try_port
            break
        except OSError as e:
            last_err = e
            if e.errno not in (48, 98):
                print(f"tm-web: bind to :{try_port} failed: {e}", file=sys.stderr)
                return 2
            if attempt == 0 and not strict_port:
                print(f"⚠ port {try_port} busy; trying {try_port+1}…", file=sys.stderr)

    if server is None:
        print(f"tm-web: no free port in {port}..{port+MAX_TRIES-1}: {last_err}", file=sys.stderr)
        return 3

    url = f"http://localhost:{port}/"
    print(f"✓ tm-web listening on {url}  (Ctrl+C to stop)")
    if open_browser:
        threading.Timer(0.3, lambda: webbrowser.open(url)).start()
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n✓ tm-web stopped")
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    sys.exit(main())
