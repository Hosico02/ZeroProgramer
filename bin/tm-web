#!/usr/bin/env python3
"""tm-web — browser dashboard for ZeroProgramer.

Two tabs:
  迭代项目 — PM state, team control buttons (start/+executor/stop), workers,
            tasks, recent events, status reports / decisions / proposals
            (click-to-view markdown content).
  Issue 管理 — gh-sync loop heartbeat (countdown to next sync), escalation
              → GitHub issue map, recent sync log.

Topbar always shows the cc-budget meter (5h/7d utilization), replacing the
retired Claude Code statusLine.

Stdlib only — no Flask, no React, no build step. Just python http.server.

Usage:
  tm-web                # listen on :7891 (default), open in browser
  tm-web 8080           # listen on :8080
  tm-web --no-open      # don't auto-launch browser
"""
from __future__ import annotations

import datetime
import http.server
import json
import os
import re
import socketserver
import subprocess
import sys
import threading
import time
import urllib.parse
import webbrowser
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
STATE_FILE = ROOT / "pm-state.json"
LOG_FILE = ROOT / "pm.log"
SUPERVISOR_LOG = ROOT / "supervisor.log"
ESC_DIR = ROOT / "escalations"
DECISIONS_DIR = ROOT / "decisions"
STATUS_REPORTS_DIR = ROOT / "status-reports"
PROPOSALS_DIR = ROOT / "proposals"
PID_FILE = ROOT / "pm.pid"
AGENT_PIDS_DIR = ROOT / "pids"
AGENT_LOGS_DIR = ROOT / "logs"
GH_MAP_FILE = ROOT / ".gh-issue-map.json"
GH_SYNC_LOG = ROOT / "gh-sync.log"
GH_SYNC_PID = ROOT / "gh-sync.pid"
GH_SYNC_STATUS = ROOT / "gh-sync.status.json"

PTY_BG = ROOT / "bin" / "_tm-pty-bg.py"
WRAPPER_SUPERVISOR = ROOT / "bin" / "tm-claude-supervisor"
WRAPPER_EXECUTOR = ROOT / "bin" / "tm-claude-executor"

# cc-budget — global Claude Code rate-limit meter.
CC_BUDGET_CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME") or (Path.home() / ".cache")) / "cc-budget"
CC_BUDGET_FILE = CC_BUDGET_CACHE_DIR / "budget.json"
CC_BUDGET_DAEMON_PID = CC_BUDGET_CACHE_DIR / "daemon.pid"
CC_BUDGET_STALE_SEC = 15 * 60

# File viewer is sandboxed to these directories — never let the browser
# read arbitrary files via /api/file?path=...
FILE_VIEWER_DIRS = (ESC_DIR, DECISIONS_DIR, STATUS_REPORTS_DIR, PROPOSALS_DIR)


# ============================================================ helpers ===
def daemon_running() -> bool:
    if not PID_FILE.exists():
        return False
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True
    except Exception:
        return False


def read_state() -> dict:
    if not STATE_FILE.exists():
        return {"tasks": [], "workers": {}}
    try:
        return json.loads(STATE_FILE.read_text())
    except Exception:
        return {"tasks": [], "workers": {}}


def tail_log(path: Path, n: int = 30) -> list[str]:
    if not path.exists():
        return []
    try:
        return path.read_text(errors="ignore").splitlines()[-n:]
    except Exception:
        return []


def list_dir_md(d: Path, n: int = 12) -> list[dict]:
    if not d.is_dir():
        return []
    items = sorted(
        (p for p in d.iterdir() if p.is_file() and p.suffix == ".md"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )[:n]
    out = []
    for p in items:
        try:
            first = p.read_text(errors="ignore").splitlines()[0]
        except Exception:
            first = "(unreadable)"
        title = first.lstrip("# ").strip() or p.stem
        out.append({
            "name": p.name,
            "title": title,
            "rel_path": str(p.relative_to(ROOT)),
            "mtime": int(p.stat().st_mtime),
        })
    return out


def read_cc_budget() -> dict:
    out = {
        "available": False, "stale": False, "daemon_alive": False,
        "ts": None, "age_sec": None,
        "h5_pct": None, "h5_reset": None,
        "d7_pct": None, "d7_reset": None,
    }
    if CC_BUDGET_DAEMON_PID.exists():
        try:
            pid = int(CC_BUDGET_DAEMON_PID.read_text().strip())
            os.kill(pid, 0)
            out["daemon_alive"] = True
        except Exception:
            pass
    if not CC_BUDGET_FILE.exists():
        return out
    try:
        d = json.loads(CC_BUDGET_FILE.read_text())
    except Exception:
        return out
    out["available"] = True
    ts = d.get("ts")
    if isinstance(ts, (int, float)):
        out["ts"] = int(ts)
        out["age_sec"] = max(0, int(time.time() - ts))
        out["stale"] = out["age_sec"] > CC_BUDGET_STALE_SEC
    rl = d.get("rate_limits", {}) or {}

    def _f(key):
        v = rl.get(key)
        try:
            return float(v) if v is not None else None
        except Exception:
            return None

    def _i(key):
        v = rl.get(key)
        try:
            return int(float(v)) if v is not None else None
        except Exception:
            return None

    out["h5_pct"] = _f("anthropic-ratelimit-unified-5h-utilization")
    out["h5_reset"] = _i("anthropic-ratelimit-unified-5h-reset")
    out["d7_pct"] = _f("anthropic-ratelimit-unified-7d-utilization")
    out["d7_reset"] = _i("anthropic-ratelimit-unified-7d-reset")
    return out


def read_gh_sync() -> dict:
    """gh-sync loop status. Combines the JSON status (if alive) with the
    .gh-issue-map.json mapping and a tail of gh-sync.log."""
    out = {
        "loop_alive": False,
        "interval_sec": 1800,
        "last_run_ts": None,
        "next_run_ts": None,
        "state": "stopped",
        "last_result": "n/a",
        "mapping": {},
        "escalations_on_disk": 0,
        "log_tail": [],
        "map_mtime": None,
    }
    if GH_SYNC_PID.exists():
        try:
            pid = int(GH_SYNC_PID.read_text().strip())
            os.kill(pid, 0)
            out["loop_alive"] = True
        except Exception:
            pass
    if GH_SYNC_STATUS.exists():
        try:
            d = json.loads(GH_SYNC_STATUS.read_text())
            for k in ("interval_sec", "last_run_ts", "next_run_ts", "state", "last_result"):
                if k in d:
                    out[k] = d[k]
        except Exception:
            pass
    if GH_MAP_FILE.exists():
        try:
            out["mapping"] = json.loads(GH_MAP_FILE.read_text())
            out["map_mtime"] = int(GH_MAP_FILE.stat().st_mtime)
        except Exception:
            pass
    if ESC_DIR.is_dir():
        out["escalations_on_disk"] = sum(
            1 for p in ESC_DIR.glob("task-*.md") if p.is_file()
        )
    out["log_tail"] = tail_log(GH_SYNC_LOG, 25)
    return out


def detect_repo() -> str | None:
    try:
        r = subprocess.run(
            ["git", "-C", str(ROOT), "remote", "get-url", "origin"],
            capture_output=True, text=True, timeout=2,
        )
        url = r.stdout.strip()
        if not url:
            return None
        m = re.search(r"[:/]([^/:]+/[^/]+?)(?:\.git)?/?$", url)
        return m.group(1) if m else url
    except Exception:
        return None


_REPO_CACHE = None
_REPO_RESOLVED = False


def cached_repo() -> str | None:
    global _REPO_CACHE, _REPO_RESOLVED
    if _REPO_RESOLVED:
        return _REPO_CACHE
    _REPO_CACHE = detect_repo()
    _REPO_RESOLVED = True
    return _REPO_CACHE


# ============================================================ agents ===
def scan_agents() -> list[dict]:
    """List currently-running agents based on pids/agent-*.pid files."""
    out = []
    if not AGENT_PIDS_DIR.is_dir():
        return out
    for pf in sorted(AGENT_PIDS_DIR.glob("agent-*.pid")):
        try:
            pid = int(pf.read_text().strip())
        except Exception:
            continue
        alive = False
        try:
            os.kill(pid, 0)
            alive = True
        except Exception:
            pass
        if not alive:
            # Stale pidfile — leave on disk so user can spot crash, but skip in list.
            continue
        label = pf.stem.replace("agent-", "")  # e.g. "supervisor" or "executor-2"
        role = "supervisor" if label.startswith("supervisor") else (
            "planner" if label.startswith("planner") else "executor"
        )
        try:
            mtime = int(pf.stat().st_mtime)
        except Exception:
            mtime = None
        out.append({
            "label": label,
            "role": role,
            "pid": pid,
            "started_ts": mtime,
            "log": f"logs/agent-{label}.log",
        })
    return out


def has_supervisor() -> bool:
    return any(a["role"] == "supervisor" for a in scan_agents())


def next_executor_index() -> int:
    used = set()
    for a in scan_agents():
        if a["role"] == "executor":
            m = re.search(r"executor-(\d+)$", a["label"])
            if m:
                used.add(int(m.group(1)))
    n = 1
    while n in used:
        n += 1
    return n


def spawn_agent(label: str, wrapper: Path) -> dict:
    """Daemonize wrapper via _tm-pty-bg.py. Returns {ok, pid|error}."""
    AGENT_LOGS_DIR.mkdir(exist_ok=True)
    AGENT_PIDS_DIR.mkdir(exist_ok=True)
    log = AGENT_LOGS_DIR / f"agent-{label}.log"
    pidf = AGENT_PIDS_DIR / f"agent-{label}.pid"
    # If the pid file exists and the process is alive, refuse — let caller decide.
    if pidf.exists():
        try:
            old = int(pidf.read_text().strip())
            os.kill(old, 0)
            return {"ok": False, "error": f"already running (pid {old})", "pid": old}
        except Exception:
            pidf.unlink(missing_ok=True)
    try:
        subprocess.run(
            [sys.executable, str(PTY_BG), str(log), str(pidf), str(wrapper), "go"],
            check=True, timeout=5,
        )
    except Exception as e:
        return {"ok": False, "error": str(e)}
    # _tm-pty-bg.py daemonizes; wait for the pidfile to appear.
    for _ in range(30):
        if pidf.exists() and pidf.stat().st_size > 0:
            try:
                pid = int(pidf.read_text().strip())
                return {"ok": True, "pid": pid, "label": label}
            except Exception:
                pass
        time.sleep(0.1)
    return {"ok": False, "error": "pid file never appeared"}


def stop_all_agents() -> dict:
    stopped = []
    if not AGENT_PIDS_DIR.is_dir():
        return {"ok": True, "stopped": stopped}
    for pf in list(AGENT_PIDS_DIR.glob("agent-*.pid")):
        try:
            pid = int(pf.read_text().strip())
            os.kill(pid, 15)  # SIGTERM
            stopped.append({"label": pf.stem.replace("agent-", ""), "pid": pid})
        except Exception:
            pass
        # Best-effort cleanup; _tm-pty-bg.py removes pidfile on its own exit.
    # Give them a moment to exit, then collect lingerers.
    time.sleep(0.4)
    for pf in list(AGENT_PIDS_DIR.glob("agent-*.pid")):
        try:
            pid = int(pf.read_text().strip())
            try:
                os.kill(pid, 0)
                # Still alive after SIGTERM — leave the pidfile, user sees the issue.
            except Exception:
                pf.unlink(missing_ok=True)
        except Exception:
            pf.unlink(missing_ok=True)
    return {"ok": True, "stopped": stopped}


