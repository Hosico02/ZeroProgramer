#!/usr/bin/env bash
# Spawn an interactive Claude session in default EXECUTOR role with auto-go +
# real-time status in the terminal title bar.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

TM_ROLE=executor "$ROOT/bin/tm-title-keeper" &
keeper=$!

if [ $# -eq 0 ]; then
  set -- "go"
fi
env TM_ROLE=executor claude "$@"
ec=$?
kill "$keeper" 2>/dev/null
exit "$ec"
