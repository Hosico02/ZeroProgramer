#!/usr/bin/env bash
# Claude Code PostToolUse hook: emit a progress event so PM knows this worker
# is alive while it's grinding through tools (Read/Edit/Bash etc.). Without
# this, a worker doing a >120s tool sequence looks identical to a crashed
# worker (no events emitted) and gets GC'd by expire_stale_workers.
set -euo pipefail

[ "${TM_AUTO:-0}" = "1" ] && exit 0

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

stdin_json=""
[ ! -t 0 ] && stdin_json=$(cat || true)

SID=$(printf '%s' "$stdin_json" | python3 -c '
import sys, json
try:
    d = json.loads(sys.stdin.read() or "{}")
    print(d.get("session_id", ""))
except Exception:
    print("")
' 2>/dev/null || true)
[ -z "$SID" ] && SID="${CLAUDE_CODE_SESSION_ID:-}"
[ -z "$SID" ] && exit 0   # no sid → nothing to ping

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
mid=$(python3 -c 'import time; print(int(time.time()*1_000_000))')
ev="$ROOT/events/${mid}_progress_${SID}.json"
python3 - "$SID" "$ts" > "$ev.tmp" <<'PY'
import json, sys
sid, ts = sys.argv[1], sys.argv[2]
print(json.dumps({"ts": ts, "type": "progress", "session_id": sid, "data": {}}))
PY
mv "$ev.tmp" "$ev"
