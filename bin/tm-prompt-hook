#!/usr/bin/env bash
# Claude Code UserPromptSubmit hook: surface any pending task or nag.
# Stdout is appended as additional context.
set -euo pipefail

[ "${TM_AUTO:-0}" = "1" ] && exit 0

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Resolve session_id authoritatively — DO NOT rely on the shared .session-id
# file (last-writer-wins across windows would mis-route tasks). Sources, in
# preference order: stdin JSON from Claude Code → CLAUDE_CODE_SESSION_ID env
# → legacy .session-id (single-window fallback only).
stdin_json=""
[ ! -t 0 ] && stdin_json=$(cat || true)
SID=$(printf '%s' "$stdin_json" | python3 -c '
import sys, json
try:
    d = json.loads(sys.stdin.read() or "{}")
    print(d.get("session_id", ""))
except Exception:
    print("")
' 2>/dev/null || true)
[ -z "$SID" ] && SID="${CLAUDE_CODE_SESSION_ID:-}"
[ -z "$SID" ] && SID=$(cat "$ROOT/.session-id" 2>/dev/null || echo "unknown")

TASK="$ROOT/tasks/$SID.task"
NAG="$ROOT/nags/$SID.nag"

if [ -f "$TASK" ]; then
  echo "📥 PM has assigned you a task. Work on it, then run \`tm-done \"<summary>\"\` to report and pull the next one."
  echo
  cat "$TASK"
  echo
  rm -f "$TASK"
fi

if [ -f "$NAG" ]; then
  echo
  cat "$NAG"
  rm -f "$NAG"
fi
